Algoritmo "L03b"
// Disciplina   : [Linguagem e Lógica de Programaçăo do visualg]
// Professor   : jailson santos da costa
// Descriçăo   : somar e exibir a som de 0 a 100
// Autor(a)    : Samuel Martins Aranha
// Data atual  : 06/04/2026
Var
   // Seçăo de Declaraçőes das variáveis

   contador: inteiro
   numero: inteiro
   somadora: inteiro
   resultado : inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   contador<- 1
   somadora<- 0
   enquanto contador <100 faça
      contador<-contador+1
      somadora<- contador+somadora
      escreva(somadora)
   fimenquanto



Fimalgoritmo